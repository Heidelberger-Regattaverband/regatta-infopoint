<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">

  <Table id="aquariusHeatsTable" autoPopinMode="true" items="{path:'aquariusHeats>/',sorter:[{path:'time',descending:true}]}" growing="true"
    growingScrollToLoad="true" growingThreshold="30" mode="SingleSelectMaster" itemPress=".onSelectionChange" sticky="ColumnHeaders"
    class="sapUiNoContentPadding">

    <columns>
      <Column id="aquariusHeatId" hAlign="Center" width="4rem" importance="High" popinDisplay="Inline">
        <header>
          <Text text="{i18n>common.id}" class="bold" />
        </header>
      </Column>
      <Column id="aquariusHeatNr" hAlign="Center" width="4rem" importance="High" popinDisplay="Inline">
        <header>
          <Text text="{i18n>common.heatNr}" class="bold" />
        </header>
      </Column>
    </columns>

    <items>
      <ColumnListItem>
        <cells>
          <Text text="{aquariusHeats>id}" />
          <Text text="{aquariusHeats>number}" />
        </cells>
      </ColumnListItem>
    </items>
  </Table>
</core:FragmentDefinition>